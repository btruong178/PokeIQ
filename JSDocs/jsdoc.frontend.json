{
  "plugins": [
    "plugins/markdown",
    "node_modules/better-docs/component"
  ],
  "tags": {
    "allowUnknownTags": [
      "component"
    ]
  },
  "source": {
    "include": [
      "frontend/src"
    ],
    "includePattern": ".+\\.(js|jsx)$",
    "excludePattern": "(node_modules|build|dist|coverage)"
  },
  "opts": {
    "destination": "docs/frontend",
    "recurse": true,
    "encoding": "utf8",
    "template": "./node_modules/docdash"
  }
}
